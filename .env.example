# Docker / Node
NODE_ENV=development

# PostgreSQL
POSTGRES_DB=budgetblade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_dev_password
POSTGRES_PORT=5432

# Backend
PORT=3000

# Laravel Auth (external service)
AUTH_BASE_URL=http://localhost:8000
AUTH_TOKEN_URL=http://localhost:8000/oauth/token
AUTH_USERINFO_URL=http://localhost:8000/api/user
AUTH_CLIENT_ID=aca va un client id de oauth --- IGNORE ---
AUTH_CLIENT_SECRET=aca va un client secret de oauth --- IGNORE ---
AUTH_SCOPE=

# Optional
AUTH_USERINFO_CACHE_TTL_MS=30000
